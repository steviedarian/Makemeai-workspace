# Daily Brief — Environment Variables
# Copy this to your workspace root .env and fill in the values.

# --- Required ---

# Google Gemini API key (for AI synthesis)
# Get it at: https://aistudio.google.com/apikey
# Click "Create API Key" → copy the key
# Free tier: 1,500 requests/day (more than enough)
GEMINI_API_KEY=

# --- Telegram (from CommandOS) ---
# These should already be set if you have CommandOS installed.
# If not, see the CommandOS module for setup instructions.
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_ID=

# --- Optional ---

# Daily Brief topic ID in your Telegram group
# This gets auto-created during installation — you don't need to set it manually.
# TELEGRAM_DAILY_BRIEF_TOPIC_ID=

# Gemini model to use (default: gemini-2.5-flash)
# Options: gemini-2.5-flash (cheapest), gemini-2.5-pro (better), gemini-3.1-pro-preview (best)
# BRIEF_MODEL=gemini-2.5-flash

# Brief schedule time (24h format, default: 07:00)
# BRIEF_TIME=07:00

# PDF report length: short, medium, comprehensive (default: medium)
# BRIEF_PDF_LENGTH=medium
