# DataOS — Environment Configuration
# Fill in values for the data sources you're connecting.
# Empty values are skipped — only fill in what you use.

# --- YouTube ---
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# --- Stripe ---
# Add one key per account: STRIPE_API_KEY_MAIN, STRIPE_API_KEY_SAAS, etc.
# Use restricted read-only keys: dashboard.stripe.com/apikeys
STRIPE_API_KEY_MAIN=

# --- Google Service Account ---
# Used by: Google Analytics, Google Sheets
# Get at: console.cloud.google.com > IAM & Admin > Service Accounts
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/google-service-account.json

# --- Google Analytics (GA4) ---
# Find at: analytics.google.com > Admin > Property Settings
GA4_PROPERTY_ID=

# --- Google Sheets ---
# Copy from the spreadsheet URL (between /d/ and /edit)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=

# --- Bitly ---
# Get at: app.bitly.com/settings/api/
BITLY_ACCESS_TOKEN=
